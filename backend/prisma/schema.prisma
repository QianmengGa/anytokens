generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 用户角色
enum Role {
  USER
  ADMIN
}

// 交易类型
enum TransactionType {
  TOPUP     // 充值
  USAGE     // API 调用扣费
  REFUND    // 退款
  BONUS     // 赠送（注册、邀请）
}

// 交易状态
enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

// 支付方式
enum PaymentMethod {
  STRIPE
  CRYPTO
  ADMIN   // 管理员手动充值
  SYSTEM  // 系统赠送
}

// 用户表
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  phone        String?
  role         Role     @default(USER)
  balance        Decimal  @default(0) @db.Decimal(12, 6)
  maxPerRequest  Decimal? @db.Decimal(12, 6) @map("max_per_request")
  maxPerDay      Decimal? @db.Decimal(12, 6) @map("max_per_day")
  maxPerMonth    Decimal? @db.Decimal(12, 6) @map("max_per_month")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  apiKeys      ApiKey[]
  transactions Transaction[]
  usageLogs    UsageLog[]

  @@map("users")
}

// 邮箱验证码表
model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, code])
  @@map("email_verifications")
}

// API 密钥表
model ApiKey {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  name       String    @default("Default Key")
  keyHash    String    @unique @map("key_hash")
  keyPrefix  String    @map("key_prefix") // 明文前缀，如 "sk-any-xxxx"
  isActive   Boolean   @default(true) @map("is_active")
  rateLimit  Int       @default(60) @map("rate_limit") // 每分钟请求数
  expiresAt  DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id])
  usageLogs UsageLog[]

  @@map("api_keys")
}

// 交易/账单表
model Transaction {
  id            String            @id @default(uuid())
  userId        String            @map("user_id")
  type          TransactionType
  amount        Decimal           @db.Decimal(12, 6)
  balanceBefore Decimal           @db.Decimal(12, 6) @map("balance_before")
  balanceAfter  Decimal           @db.Decimal(12, 6) @map("balance_after")
  status        TransactionStatus @default(PENDING)
  paymentMethod PaymentMethod?    @map("payment_method")
  externalId    String?           @map("external_id") // Stripe/NOWPayments 订单 ID
  description   String?
  metadata      Json?
  createdAt     DateTime          @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("transactions")
}

// API 调用日志表
model UsageLog {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  apiKeyId         String?  @map("api_key_id")
  model            String   // 模型名称
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")
  cost             Decimal  @db.Decimal(12, 8) // 本次调用费用 USD
  latencyMs        Int?     @map("latency_ms")
  status           String   @default("success") // success / error
  errorMessage     String?  @map("error_message")
  createdAt        DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id])
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id])

  @@index([userId, createdAt])
  @@index([model, createdAt])
  @@map("usage_logs")
}
