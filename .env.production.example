# ==================== Anytokens 生产环境配置 ====================
# 复制此文件为 .env.production 并填入真实值
# cp .env.production.example .env.production

# ==================== 数据库 ====================
POSTGRES_USER=anytokens
POSTGRES_PASSWORD=<strong-random-password>
POSTGRES_DB=anytokens
REDIS_PASSWORD=<strong-random-password>

# ==================== 认证 ====================
JWT_SECRET=<random-64-char-string>
NEXTAUTH_SECRET=<random-64-char-string>
NEXTAUTH_URL=https://anytokens.net

# ==================== 域名 ====================
CORS_ORIGIN=https://anytokens.net
FRONTEND_URL=https://anytokens.net
NEXT_PUBLIC_API_URL=https://api.anytokens.net/api/v1
NEXT_PUBLIC_API_BASE=https://api.anytokens.net

# ==================== 邮件服务 (Resend) ====================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== AI 模型供应商 ====================
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ==================== Stripe 支付 ====================
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== NOWPayments 加密货币 ====================
NOWPAYMENTS_API_KEY=XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX
NOWPAYMENTS_IPN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 管理员 ====================
ADMIN_EMAIL=admin@anytokens.net
